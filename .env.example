# KCB OAuth Configuration
# ========================

# The base URL for the KCB provider
# Example: https://auth.kcb.com or https://kcb-staging.example.com
KCB_BASE_URL=https://kcb-auth.example.com

# OAuth 2.0 Authorization Endpoint (path relative to base URL)
# Example: /oauth/authorize or /oauth2/authorization
KCB_AUTH_ENDPOINT=/oauth/authorize

# OAuth 2.0 Token Endpoint (path relative to base URL)
# Example: /oauth/token or /oauth2/token
KCB_TOKEN_ENDPOINT=/oauth/token

# OAuth 2.0 User Info Endpoint (path relative to base URL)
# Example: /oauth/userinfo or /oauth2/userinfo
KCB_USER_INFO_ENDPOINT=/oauth/userinfo

# OAuth Client ID
# Obtain from KCB provider dashboard
# Format: typically alphanumeric string
KCB_CLIENT_ID=your_client_id_here

# OAuth Client Secret
# Obtain from KCB provider dashboard
# ⚠️  NEVER commit this to version control
# ⚠️  Keep this secret and secure
KCB_CLIENT_SECRET=your_client_secret_here

# OAuth Redirect URI
# Must match exactly the URI registered with KCB provider
# For local development: http://localhost:3000/api/auth/kcb/callback
# For production: https://yourdomain.com/api/auth/kcb/callback
KCB_REDIRECT_URI=http://localhost:3000/api/auth/kcb/callback

# OAuth Scopes
# Space-separated list of scopes to request from KCB
# Common scopes: openid, profile, email
# Check KCB documentation for available scopes
KCB_SCOPE=openid profile email

# Success Redirect URL
# Where to redirect user after successful OAuth callback
# Defaults to /dashboard
KCB_SUCCESS_REDIRECT_URL=/dashboard

# Enable Debug Logging
# Set to 'true' to enable verbose logging for troubleshooting
KCB_DEBUG=false

# Neon Database Configuration
# ============================

# PostgreSQL connection string for Neon
# Format: postgresql://user:password@host/database
# Obtain from Neon dashboard
DATABASE_URL=postgresql://user:password@host/database

# Node Environment
# Development: http://localhost:3000
# Production: https://yourdomain.com
NODE_ENV=development
