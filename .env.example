# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# M-Pesa Configuration (Existing)
VITE_MPESA_CONSUMER_KEY=your_mpesa_consumer_key
VITE_MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
VITE_MPESA_PASSKEY=your_mpesa_passkey
VITE_MPESA_SHORTCODE=your_mpesa_shortcode
VITE_MPESA_CALLBACK_URL=https://your-domain.com/api/payments/mpesa/callback

# KCB BUNI Configuration
VITE_KCB_BASE_URL=https://api.sandbox.kcb.co.ke
VITE_KCB_CLIENT_ID=your_kcb_client_id
VITE_KCB_CLIENT_SECRET=your_kcb_client_secret
VITE_KCB_ROUTE_CODE=207
VITE_KCB_SHARED_SHORTCODE=true
VITE_KCB_ORG_SHORTCODE=your_org_shortcode
VITE_KCB_ORG_PASSKEY=your_org_passkey
VITE_KCB_CALLBACK_URL=https://your-domain.com/api/payments/kcb/ipn
VITE_KCB_PUBLIC_CERT_PATH=/certs/kcb-public.pem

# Application Configuration
VITE_APP_NAME=Jimwas POS
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=development

# Analytics (Optional)
VITE_ANALYTICS_ID=
